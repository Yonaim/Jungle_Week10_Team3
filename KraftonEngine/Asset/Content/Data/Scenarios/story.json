      "control_room_baek_0": "Asset/Content/Texture/Story/control_room_screen_on_baek_0.png",
      "control_room_baek_1": "Asset/Content/Texture/Story/control_room_screen_on_baek_1.png",
      "control_room_lim_0": "Asset/Content/Texture/Story/control_room_screen_on_lim_0.png",
      "control_room_lim_1": "Asset/Content/Texture/Story/control_room_screen_on_lim_1.png",
      "control_room_pod": "Asset/Content/Texture/Story/control_room_screen_pod.png",
      "control_room_baek_lim_0": "Asset/Content/Texture/Story/control_room_screen_on_baek_lim_0.png",
      "control_room_baek_lim_1": "Asset/Content/Texture/Story/control_room_screen_on_baek_lim_1.png"
    },
    "sounds": {
      "boot_startup": "Asset/Content/Sound/Background/04. Cutscene 1.mp3",
      "crt_on": "Asset/Content/Sound/SFX/crt-on.mp3",
      "go": "Sound.SFX.go",
      "stage_intro": "Asset/Content/Sound/Background/06. Stage Intro.wav"
    }
  },
  "prologue": {
    "introFadeSeconds": 6.8,
    "introHoldSeconds": 1.5,
    "outroFadeSeconds": 0.9,
    "controlRoomFadeSeconds": 0.9,
    "crtLeadSeconds": 0.0,
    "crtSwitchDelaySeconds": 0.2,
    "postCrtHoldSeconds": 1.2,
    "lines": [
      "JUNGLE Tech Lab.",
      "교육생들이 직접 만든 게임 엔진을 기반으로,",
      "실전형 개발 훈련을 진행하는 기술 교육 기관.",
      "이곳에서 엔진은 단순한 과제가 아니다.",
      "Redering, Collision, Runtime, Debugging까지",
      "모든 시스템이 교육생의 실력을 검증하는 훈련장이 된다."
    ]
  },
  "sequence": [
    {
      "id": "intro_010_baek_01",
      "type": "dialogue",
      "speaker": "BAEK_COMMANDER",
      "background": "control_room_baek_1",
      "message": "JUNGLE Tech Lab 내부 엔진에서 원인 불명의\n런타임 오류가 감지됐다."
    },
    {
      "id": "intro_011_baek_02",
      "type": "dialogue",
      "speaker": "BAEK_COMMANDER",
      "background": "control_room_baek_1",
      "message": "외부 로그 분석과 일반 디버거로는 원인을 추적할 수\n없다."
    },
    {
      "id": "intro_012_baek_03",
      "type": "dialogue",
      "speaker": "BAEK_COMMANDER",
      "background": "control_room_baek_1",
      "message": "오류는 엔진 내부 깊은 런타임 구간에서 발생하고 있으며, 시간이 지날수록 시스템 안정도가 하락하고 있다."
    },
    {
      "id": "intro_015_baek_04",
      "type": "dialogue",
      "speaker": "BAEK_COMMANDER",
      "background": "control_room_baek_1",
      "message": "따라서 지금부터 교육생을 디버그 포드에 탑승시켜 엔진 내부로 직접 투입한다."
    },
    {
      "id": "intro_016_pod_01",
      "type": "image",
      "background": "control_room_pod",
      "duration": 2.5
    },
    {
      "id": "intro_017_im_01",
      "type": "dialogue",
      "speaker": "LIM_COMMANDER",
      "background": "control_room_lim_1",
      "message": "쉽게 말하면, 네가 직접 엔진 안으로 들어가서 어디서 터지는지 보고 오라는 뜻이다."
    },
    {
      "id": "intro_018_im_02",
      "type": "dialogue",
      "speaker": "LIM_COMMANDER",
      "background": "control_room_lim_1",
      "message": "걱정 마라. 포드는 튼튼하다. 아마도."
    },
    {
      "id": "intro_020_baek_05",
      "type": "dialogue",
      "speaker": "BAEK_COMMANDER",
      "background": "control_room_baek_lim_1",
      "message": "불필요한 설명은 줄이도록."
    },
    {
      "id": "intro_021_im_03",
      "type": "dialogue",
      "speaker": "LIM_COMMANDER",
      "background": "control_room_baek_lim_1",
      "message": "긴장 풀어주려는 거지."
    },
    {
      "id": "intro_021_im_04",
      "type": "dialogue",
      "speaker": "LIM_COMMANDER",
      "background": "control_room_baek_lim_1",
      "message": "지금부터 검은 화면, 그리드, 버그, 오류 패널이\n아주 친절하게 반겨줄 거다."
    },
    {
      "id": "intro_023_baek_06",
      "type": "dialogue",
      "speaker": "BAEK_COMMANDER",
      "background": "control_room_baek_1",
      "message": "목표는 명확하다."
    },
    {
      "id": "intro_024_baek_07",
      "type": "dialogue",
      "speaker": "BAEK_COMMANDER",
      "background": "control_room_baek_1",
      "message": "엔진 내부를 질주하며 Log 조각을 수집하고, 해당 Trace 데이터를 통해 오류의 근원을 추적해라."
    },
    {
      "id": "intro_025_baek_08",
      "type": "dialogue",
      "speaker": "BAEK_COMMANDER",
      "background": "control_room_baek_1",
      "message": "Trace가 충분히 쌓이면 Hotfix를 적용할 수 있다. Stability가 0%가 되면 디버그 세션은 강제 종료된다."
    },
    {
      "id": "intro_026_im_04",
      "type": "dialogue",
      "speaker": "LIM_COMMANDER",
      "background": "control_room_baek_lim_1",
      "message": "즉, Log는 먹고, Error는 피하고, 무한 Debugging 지옥에서 살아남으면 된다."
    },
    {
      "id": "intro_027_im_05",
      "type": "dialogue",
      "speaker": "LIM_COMMANDER",
      "background": "control_room_baek_lim_1",
      "message": "아주 간단하지. 물론 말로만."
    },
    {
      "id": "intro_029_baek_09",
      "type": "dialogue",
      "speaker": "BAEK_COMMANDER",
      "background": "control_room_baek_1",
      "message": "교육생, 동기화 상태 확인."
    },
    {
      "id": "intro_030_baek_10",
      "type": "dialogue",
      "speaker": "BAEK_COMMANDER",
      "background": "control_room_baek_1",
      "message": "지금부터 네 기록은 JUNGLE Tech Lab 훈련 시스템에 저장된다."
    },
    {
      "id": "intro_031_baek_11",
      "type": "dialogue",
      "speaker": "BAEK_COMMANDER",
      "background": "control_room_baek_1",
      "message": "가능한 한 깊은 런타임 구간까지 진입해라."
    },
    {
      "id": "intro_032_im_06",
      "type": "dialogue",
      "speaker": "LIM_COMMANDER",
      "background": "control_room_lim_1",
      "message": "그리고 가능하면 멋있게 해라.\n우리의 평가 기준은 꽤나 깐깐하다."
    },
    {
      "id": "intro_034_baek_12",
      "type": "dialogue",
      "speaker": "BAEK_COMMANDER",
      "background": "control_room_baek_1",
      "message": "디버그 포드, 투입."
    },
    {
      "id": "intro_035_im_07",
      "type": "dialogue",
      "speaker": "LIM_COMMANDER",
      "background": "control_room_lim_1",
      "message": "자, 엔진 속으로 뛰어들어라!"
    }
  ]
}
